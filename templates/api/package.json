{
  "name": "api",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./client": {
      "types": "./src/client.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsup src/index.ts --format esm --target node22 --dts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@orpc/client": "^1.13.4",
    "@orpc/server": "^1.13.4",
    "@sentry/node": "^9.27.0",
    "hono": "^4.8.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
