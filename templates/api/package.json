{
  "name": "api",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./client": {
      "types": "./src/client.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --target node22 --dts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config ../../packages/db/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config ../../packages/db/drizzle.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@hono/node-server": "^1.14.1",
    "@hono/node-ws": "^1.1.1",
    "@orpc/client": "^1.13.4",
    "@orpc/server": "^1.13.4",
    "@sentry/node": "^9.27.0",
    "{{scope}}/db": "workspace:*",
    "{{scope}}/shared": "workspace:*",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.8.1",
    "ioredis": "^5.9.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "rabbitmq-client": "^5.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.8",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
